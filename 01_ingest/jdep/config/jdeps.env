# jdeps.env — jdeps ingestion configuration reference
# =============================================================================
# This file documents the env vars consumed by 01_ingest/jdep/scripts/*.ps1.
# It is NOT loaded directly — values live in 00_orchestrate/config/archim8.env
# and are overridden per-developer in 00_orchestrate/config/archim8.local.env.
#
# To customise for your machine, add any of these keys to:
#   00_orchestrate/config/archim8.local.env   (gitignored)
# =============================================================================

# ---------------------------------------------------------------------------
# Target repository
# ---------------------------------------------------------------------------
# Absolute path to the Maven reactor root (the folder containing your
# top-level pom.xml). jdeps-run.ps1 will recurse from here to collect JARs.
# Must be set in archim8.local.env — there is no safe default.
ARCHIM8_TARGET_REPO=C:\path\to\your\java\project

# ---------------------------------------------------------------------------
# Output artefact names
# Written into: 02_store/neo4j/docker/import/
# ---------------------------------------------------------------------------
ARCHIM8_JDEPS_OUTPUT=jdeps-output.txt
ARCHIM8_JDEPS_EDGES_CSV=jdeps-jar-edges.csv

# ---------------------------------------------------------------------------
# JAR exclusion patterns applied by jdeps-run.ps1
# (matched against .Name, case-insensitive)
# ---------------------------------------------------------------------------
# *-sources.jar          source archives
# *-tests.jar            test JARs
# *-test.jar             test JARs (alternate naming)
# *-javadoc.jar          Javadoc archives
# *-test-fixtures.jar    test fixture JARs
# original-*.jar         pre-shade originals (Maven Shade plugin)
# *-shaded.jar           fat/shaded JARs
