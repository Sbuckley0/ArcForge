# =============================================================================
# archim8.env — Committed defaults
# =============================================================================
# This file contains safe, project-wide defaults.  It IS tracked in git.
# Do NOT put real passwords or absolute machine paths here.
#
# To override locally, create  01_config/archim8.local.env  (gitignored)
# and set only the keys you want to change.  Local wins over these defaults.
# =============================================================================

# ---------------------------------------------------------------------------
# Target application identity
# ---------------------------------------------------------------------------
# The English name of the Java project being analysed.
# Spaces are fine — everything else (labels, namespaces, filenames) is derived.
ARCHIM8_TARGET_APP=YourAppName

# (Optional) Override the output architecture document base name.
# Leave blank to auto-derive (e.g. "My App" → "My-App_Architecture").
ARCHIM8_OUTPUT_DOC=

# ---------------------------------------------------------------------------
# Target repository
# ---------------------------------------------------------------------------
# Absolute path to the Maven reactor root of the Java project to analyse.
# Override in archim8.local.env with your real path.
# See also: 01_ingest/jdep/config/jdeps.env for jdeps-specific documentation.
ARCHIM8_TARGET_REPO=C:\path\to\your\java\project

# ---------------------------------------------------------------------------
# Neo4j connection
# ---------------------------------------------------------------------------
ARCHIM8_NEO4J_USER=neo4j
ARCHIM8_NEO4J_PASSWORD=password
ARCHIM8_NEO4J_HTTP=http://localhost:7474
ARCHIM8_NEO4J_BOLT=bolt://localhost:7687

# ---------------------------------------------------------------------------
# Neo4j Docker volume mounts
# data and logs default to ./data and ./logs inside 02_store/neo4j/docker/
# (created automatically by Docker on first run — no action needed).
# Override only if you need volumes stored elsewhere.
# ---------------------------------------------------------------------------
# Recommended: point both to the 05_deliver/input pipeline dirs so that
# jdeps output and APOC exports land alongside other pipeline deliverables.
#   ARCHIM8_NEO4J_IMPORT_DIR=C:\<archim8-root>\05_deliver\input\01_ingest
#   ARCHIM8_NEO4J_EXPORT_DIR=C:\<archim8-root>\05_deliver\input\03_query
ARCHIM8_NEO4J_IMPORT_DIR=
ARCHIM8_NEO4J_EXPORT_DIR=

# ---------------------------------------------------------------------------
# jdeps artefact names (written into the neo4j import folder)
# ---------------------------------------------------------------------------
ARCHIM8_JDEPS_OUTPUT=jdeps-output.txt
ARCHIM8_JDEPS_EDGES_CSV=jdeps-jar-edges.csv
