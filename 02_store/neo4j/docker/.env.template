# .env.template — copy to .env and fill in your values
# This file IS tracked in git.  The generated .env is NOT.
#
# Usage:
#   Copy-Item .env.template .env   # Windows PowerShell
#   cp .env.template .env          # bash / macOS / Linux
# Then edit .env with real absolute paths for your machine.

# --- Neo4j auth (format: user/password) ---
NEO4J_AUTH=neo4j/password
NEO4J_PASSWORD=password

# --- Persistent volume paths ---
# Leave blank to use ./data and ./logs relative to this docker-compose.yml (recommended).
# Override with absolute paths only if you need volumes stored elsewhere.
#   ARCHIM8_NEO4J_DATA_DIR=C:\dev\archim8-neo4j\data
#   ARCHIM8_NEO4J_LOGS_DIR=C:\dev\archim8-neo4j\logs
ARCHIM8_NEO4J_DATA_DIR=
ARCHIM8_NEO4J_LOGS_DIR=

# --- Import / export paths (leave blank to use ./import and ./export) ---
ARCHIM8_NEO4J_IMPORT_DIR=
ARCHIM8_NEO4J_EXPORT_DIR=
